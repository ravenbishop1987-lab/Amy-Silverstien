# Application
APP_NAME=Amy Chatbot
SECRET_KEY=your-super-secret-key-change-this-in-production
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
WIDGET_URL=http://localhost:5174

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com

# Magic-link email
MAGIC_LINK_EXPIRE_MINUTES=15
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Amy

# Database
DATABASE_URL=postgresql+asyncpg://amy_user:amy_password@localhost:5432/amy_chatbot

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic / Claude
ANTHROPIC_API_KEY=sk-ant-...

# ElevenLabs
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...   # Amy's voice ID from ElevenLabs

# OpenAI (Whisper speech-to-text)
OPENAI_API_KEY=sk-...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...     # $9.99/month
STRIPE_PRICE_CREDITS_SINGLE=price_...     # $0.99 single voice conversation
STRIPE_PRICE_CREDITS_BULK=price_...       # $2.99 for 50 voice conversations

# Pinecone (vector DB)
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=amy-memories

# Free tier limits
FREE_DAILY_CONVERSATIONS=3

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours
REFRESH_TOKEN_EXPIRE_DAYS=30
