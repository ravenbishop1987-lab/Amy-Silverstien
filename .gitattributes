# Normalize line endings
* text=auto

# Windows scripts keep CRLF
*.bat text eol=crlf

# Force LF for everything else
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.html text eol=lf
*.env.example text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.woff2 binary
